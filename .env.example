# ─────────────────────────────────────────────────────────────────────────────
# Anonymous card voting (thumbs up / thumbs down) — optional backend config
# ─────────────────────────────────────────────────────────────────────────────
#
# The site works without these (votes fall back to per-browser localStorage).
# To share vote counts globally across all visitors, configure a free Supabase
# project below.
#
# SETUP
# 1. Create a free project at https://supabase.com
# 2. In the project's SQL editor, run the SQL block at the bottom of this file.
# 3. Copy your Project URL and the "anon" public API key
#    (Project Settings → API) into a local, git-ignored .env.local file:
#
#        VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
#        VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
#
# NOTE: The anon key is public by design and safe to ship in a static site.
#       Votes are anonymous — no login, cookies, or personal data are sent.
#       Row-level security below blocks direct table writes; only the
#       `apply_vote` RPC can change counts.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Supabase SQL — run once in the SQL editor
# ─────────────────────────────────────────────────────────────────────────────
#
# create table if not exists public.card_votes (
#   card_id text primary key,
#   up      integer not null default 0,
#   down    integer not null default 0
# );
#
# alter table public.card_votes enable row level security;
#
# -- Anyone may read aggregate counts.
# create policy "read card votes" on public.card_votes
#   for select to anon using (true);
#
# -- Atomic, anonymous vote application. Deltas are +1/-1 computed by the client.
# create or replace function public.apply_vote(p_card_id text, p_up integer, p_down integer)
#   returns public.card_votes
#   language plpgsql
#   security definer
#   set search_path = public
# as $$
# declare
#   result public.card_votes;
# begin
#   insert into public.card_votes (card_id, up, down)
#   values (p_card_id, greatest(p_up, 0), greatest(p_down, 0))
#   on conflict (card_id) do update
#     set up   = greatest(public.card_votes.up   + p_up,   0),
#         down = greatest(public.card_votes.down + p_down, 0)
#   returning * into result;
#   return result;
# end;
# $$;
#
# grant execute on function public.apply_vote(text, integer, integer) to anon;
